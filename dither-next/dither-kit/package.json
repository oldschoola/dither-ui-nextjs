{
  "name": "dither-kit",
  "version": "0.1.0",
  "description": "Dithered UI toolkit — composable ordered-dither charts (area, line, bar, pie, radar) on one tiny canvas engine, plus generative avatars, buttons, gradient washes and more. React port.",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "module": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./*": "./*"
  },
  "files": [
    "*.ts",
    "*.tsx"
  ],
  "sideEffects": false,
  "peerDependencies": {
    "clsx": "^2.1.0",
    "d3-scale": "^4.0.0",
    "d3-shape": "^3.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.0"
  },
  "peerDependenciesMeta": {
    "react": { "optional": true },
    "react-dom": { "optional": true }
  },
  "keywords": [
    "react",
    "charts",
    "dither",
    "canvas",
    "ui-kit",
    "generative"
  ],
  "license": "MIT"
}
